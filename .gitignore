# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
*.pem
*-key.pem
localhost*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env / secrets — never commit
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# vercel / cloudflare local state — never commit
.vercel
**/.vercel
.wrangler
**/.wrangler

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
**/__pycache__/
*.pyc
.venv/
**/.venv/
program/.venv/

# program runtime / local install state
program/data/
program/osb_config.json
program/.stress-sandbox/
program/data/_stress-reports/
program/**/session_secret.txt
program/**/ai_secrets.json
**/session_secret.txt
**/ai_secrets.json

# editor / OS
.idea/
.vscode/
*.swp
*~
